<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}AgentSurface{% endblock %}</title>

  <!-- Open Graph meta tags -->
  <meta property="og:title" content="{% block og_title %}AgentSurface — AI Agent Readiness Leaderboard{% endblock %}">
  <meta property="og:description" content="{% block og_description %}AgentSurface — AI Agent Readiness Leaderboard{% endblock %}">
  <meta property="og:image" content="{{ og_image | default('') }}">
  <meta property="og:url" content="{{ og_url | default('') }}">

  {% block extra_head %}{% endblock %}
  <style>
    /* ── Reset & tokens ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #ffffff;
      --bg-subtle: #f5f5f5;
      --border:    #d1d5db;
      --text:      #111827;
      --text-muted:#6b7280;
      --link:      #2563eb;
      --link-hover:#1d4ed8;
      --nav-bg:    #1e293b;
      --nav-text:  #f1f5f9;
      --nav-active:#38bdf8;

      /* grade colours */
      --grade-a:   #22c55e;
      --grade-b:   #3b82f6;
      --grade-c:   #eab308;
      --grade-d:   #f97316;
      --grade-f:   #ef4444;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg:        #0f172a;
        --bg-subtle: #1e293b;
        --border:    #334155;
        --text:      #f1f5f9;
        --text-muted:#94a3b8;
        --link:      #60a5fa;
        --link-hover:#93c5fd;
        --nav-bg:    #020617;
        --nav-text:  #f1f5f9;
        --nav-active:#38bdf8;
      }
    }

    /* ── Base ───────────────────────────────────────────────────── */
    html { font-size: 16px; }

    body {
      font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas,
                   "Liberation Mono", monospace;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    a            { color: var(--link); text-decoration: none; }
    a:hover      { color: var(--link-hover); text-decoration: underline; }
    h1, h2, h3   { line-height: 1.25; }
    h1           { font-size: 1.75rem; margin-bottom: 0.75rem; }
    h2           { font-size: 1.25rem; margin-bottom: 0.5rem; }
    h3           { font-size: 1.05rem; margin-bottom: 0.4rem; }
    p            { margin-bottom: 0.75rem; }
    pre, code    { font-family: inherit; }

    /* ── Header / sticky nav ────────────────────────────────────── */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--nav-bg);
    }

    nav {
      background: var(--nav-bg);
      color: var(--nav-text);
      padding: 0.6rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    nav .brand {
      font-weight: 700;
      font-size: 1rem;
      color: var(--nav-active);
      letter-spacing: 0.05em;
      text-decoration: none;
    }

    nav .nav-links { display: flex; gap: 1.5rem; list-style: none; }

    nav .nav-links a {
      color: var(--nav-text);
      font-size: 0.875rem;
      transition: color 0.15s;
    }

    nav .nav-links a:hover { color: var(--nav-active); text-decoration: none; }

    /* ── Main content ───────────────────────────────────────────── */
    main {
      flex: 1;
      max-width: 1100px;
      width: 100%;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* ── Tables ─────────────────────────────────────────────────── */
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
    }

    th, td {
      padding: 0.5rem 0.75rem;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    th {
      background: var(--bg-subtle);
      font-weight: 600;
      white-space: nowrap;
    }

    tbody tr:hover { background: var(--bg-subtle); }

    /* ── Cards / panels ─────────────────────────────────────────── */
    .panel {
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 1.5rem;
      background: var(--bg-subtle);
    }

    /* ── Grade badges ───────────────────────────────────────────── */
    .grade {
      display: inline-block;
      font-weight: 700;
      padding: 0.15em 0.5em;
      border-radius: 4px;
      font-size: 0.9em;
      color: #fff;
    }

    .grade-A, .grade-Aplus, .grade-Aminus { background: var(--grade-a); }
    .grade-B, .grade-Bplus, .grade-Bminus { background: var(--grade-b); }
    .grade-C, .grade-Cplus, .grade-Cminus { background: var(--grade-c); color: #111; }
    .grade-D, .grade-Dplus, .grade-Dminus { background: var(--grade-d); }
    .grade-F                               { background: var(--grade-f); }

    /* ── Details / summary ──────────────────────────────────────── */
    details { margin-bottom: 0.5rem; }

    summary {
      cursor: pointer;
      padding: 0.35rem 0.5rem;
      border-radius: 4px;
      font-size: 0.875rem;
      user-select: none;
      list-style: none;
    }

    summary::-webkit-details-marker { display: none; }
    summary::before { content: "▶ "; font-size: 0.7em; }
    details[open] summary::before { content: "▼ "; }
    summary:hover { background: var(--bg-subtle); }

    /* ── Code / pre ─────────────────────────────────────────────── */
    pre {
      background: var(--bg-subtle);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.75rem 1rem;
      overflow-x: auto;
      font-size: 0.8rem;
      line-height: 1.5;
      margin-bottom: 1rem;
    }

    /* ── Utilities ──────────────────────────────────────────────── */
    .text-muted  { color: var(--text-muted); font-size: 0.85em; }
    .text-right  { text-align: right; }
    .mt-1        { margin-top: 0.5rem; }
    .mt-2        { margin-top: 1rem; }
    .mb-1        { margin-bottom: 0.5rem; }
    .mb-2        { margin-bottom: 1rem; }

    /* ── Footer ─────────────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding: 1rem 1.5rem;
      text-align: center;
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    footer a { color: var(--text-muted); text-decoration: underline; }
    footer a:hover { color: var(--link-hover); }

    /* ── Signal status icons ────────────────────────────────────── */
    .sig-pass    { color: var(--grade-a); }
    .sig-fail    { color: var(--grade-f); }
    .sig-partial { color: var(--grade-c); }

    /* ── Score bar (TASK-106) ───────────────────────────────────── */
    .score-bar {
      display: inline-block;
      width: 100px;
      height: 10px;
      background: var(--border);
      border-radius: 5px;
      vertical-align: middle;
      overflow: hidden;
      margin-right: 0.4rem;
    }

    .score-fill {
      display: block;
      height: 100%;
      border-radius: 5px;
      background: var(--grade-b);
      transition: width 0.3s ease;
    }

    /* ── Copy badge button ──────────────────────────────────────── */
    .copy-btn {
      font-family: inherit;
      font-size: 0.8rem;
      padding: 0.2rem 0.6rem;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--bg);
      color: var(--text);
      cursor: pointer;
      margin-left: 0.5rem;
      vertical-align: middle;
    }

    .copy-btn:hover { background: var(--bg-subtle); }
  </style>
</head>
<body>

  <header>
    <nav>
      <a class="brand" href="/index.html">AgentSurface</a>
      <ul class="nav-links">
        <li><a href="/index.html">Leaderboard</a></li>
        <li><a href="/framework.html">Framework</a></li>
        <li><a href="/submit.html">Submit API</a></li>
      </ul>
    </nav>
  </header>

  <main>
    {% block content %}{% endblock %}
  </main>

  <footer>
    AgentSurface &mdash; MIT License |
    Framework spec: <a href="/framework.html">CC-BY-4.0</a>
  </footer>

  {% block extra_scripts %}{% endblock %}
</body>
</html>
